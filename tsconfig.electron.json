{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020"],
    "skipLibCheck": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "outDir": "dist-electron",
    "rootDir": "electron",
    "strict": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "checkJs": false,
    "allowJs": true
  },
  "include": ["electron/**/*.js", "electron/**/*.ts"],
  "exclude": ["node_modules", "dist", "src"]
}
