{
  "name": "onehand",
  "version": "0.1.0",
  "description": "智能语音笔记桌面应用 - Intelligent Voice Notebook Desktop Application",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build && electron-builder",
    "build:dir": "vue-tsc && vite build && electron-builder --dir",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on -t 60000 http://localhost:5173 || true && tsc -p tsconfig.electron.json && electron .\"",
    "electron:build": "vite build && tsc -p tsconfig.electron.json && electron-builder",
    "electron:build:win": "vite build && tsc -p tsconfig.electron.json && electron-builder --win",
    "electron:build:mac": "vite build && tsc -p tsconfig.electron.json && electron-builder --mac",
    "electron:build:linux": "vite build && tsc -p tsconfig.electron.json && electron-builder --linux"
  },
  "keywords": [
    "electron",
    "vue",
    "voice",
    "notebook",
    "ai",
    "transcription"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@vitejs/plugin-vue": "^4.6.2",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "pinia": "^2.3.1",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vue": "^3.5.29",
    "vue-router": "^4.6.4",
    "vue-tsc": "^1.8.27",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "marked": "^17.0.4"
  }
}
