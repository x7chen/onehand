{
  "name": "onehand",
  "version": "0.30.0",
  "type": "module",
  "description": "智能语音笔记桌面应用 - Intelligent Voice Notebook Desktop Application",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "npm run electron:dev",
    "build": "npm run download-model && vue-tsc && vite build && electron-builder",
    "build:dir": "npm run download-model && vue-tsc && vite build && electron-builder --dir",
    "preview": "vite preview",
    "electron:dev": "npm run download-model && vue-tsc && vite build && tsc -p tsconfig.electron.json && electron .",
    "electron:build": "npm run download-model && vite build && tsc -p tsconfig.electron.json && electron-builder",
    "electron:build:win": "npm run download-model && vite build && tsc -p tsconfig.electron.json && electron-builder --win",
    "electron:build:mac": "npm run download-model && vite build && tsc -p tsconfig.electron.json && electron-builder --mac",
    "download-model": "node scripts/download-model.js",
    "postinstall": "npm run download-model"
  },
  "keywords": [
    "electron",
    "vue",
    "voice",
    "notebook",
    "ai",
    "transcription"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/md5": "^2.3.5",
    "@types/node": "^20.19.37",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-vue": "^4.6.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "pinia": "^2.3.1",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vue": "^3.5.29",
    "vue-router": "^4.6.4",
    "vue-tsc": "latest"
  },
  "dependencies": {
    "@langchain/textsplitters": "^1.0.0",
    "@libsql/client": "^0.15.15",
    "@llm-tools/embedjs": "^0.1.31",
    "@llm-tools/embedjs-interfaces": "^0.1.31",
    "@llm-tools/embedjs-libsql": "^0.1.31",
    "@types/three": "^0.184.0",
    "debug": "^4.4.3",
    "hast-util-from-html": "^2.0.3",
    "hast-util-to-html": "^9.0.5",
    "katex": "^0.16.25",
    "md5": "^2.3.0",
    "mermaid": "^11.6.0",
    "pdfjs-dist": "^4.7.76",
    "rehype-external-links": "^3.0.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-cjk-friendly": "^2.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "sherpa-onnx": "^1.12.29",
    "shiki": "^4.0.2",
    "three": "^0.184.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "uuid": "^13.0.0",
    "vue-i18n": "^11.3.0",
    "vue-tsc": "^3.2.6"
  }
}
